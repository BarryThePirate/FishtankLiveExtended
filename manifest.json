{
  "manifest_version": 3,
  "name": "Fishtank Live Extended",
  "version": "2.2.1",
  "description": "An open source project aimed at extending functionality on fishtank.live",
  "permissions": [],
  "host_permissions": [
    "https://cdn.fishtank.live/*"
  ],
  "background": {
    "service_worker": "current/background.js"
  },
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "content_scripts": [
    {
      "matches": ["*://classic.fishtank.live/*"],
      "css": ["classic/styles.css"],
      "js": [
        "classic/settings.js",
        "classic/helpers.js",
        "classic/general.js",
        "classic/item-crafting.js",
        "classic/settings-editor.js",
        "classic/anti-spam.js",
        "classic/filter.js",
        "classic/logging.js",
        "classic/video-player-observe.js",
        "classic/offline-recipes.js",
        "classic/init.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://fishtank.live/*", "*://www.fishtank.live/*"],
      "js": ["current/bundle.js"],
      "run_at": "document_idle"
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "fishtank-live-extended@fishtank.live",
      "strict_min_version": "109.0"
    }
  },
  "web_accessible_resources": [
    {
      "resources": ["current/chat-filter.js"],
      "matches": ["*://fishtank.live/*", "*://www.fishtank.live/*"]
    }
  ]
}